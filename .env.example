# Copy this file to ".env" and fill in your own values.
# The real .env is gitignored so secrets never end up on GitHub.

# Postgres connection string.
# Local example:  postgres://postgres:postgres@localhost:5432/uptime
# A free cloud database (Neon, Supabase, Render) will give you a string like:
#   postgres://user:password@some-host.neon.tech/dbname
DATABASE_URL=postgres://postgres:postgres@localhost:5432/uptime

# Set to "true" if your database requires SSL (most cloud providers do).
PGSSL=false

# Secret used to sign the login session cookie. Use a long random string in production.
SESSION_SECRET=change-me-to-something-random

# Port the web server listens on (optional, defaults to 3000).
PORT=3000
